-- webhooks
local function SendWebhook(msg, ping)
    if getgenv().Config.Settings.Webhook == "" then
        return
    end
    
    local url = getgenv().Config.Settings.Webhook
    local content = ping and "@everyone" or ""
    local data = {
        ["content"] = content,
        ["embeds"] = {{
            ["description"] = msg,
            ["type"] = "rich",
            ["color"] = tonumber(0x000000),
        }}
    }
    
    local newdata = HttpService:JSONEncode(data)
    local headers = {["Content-Type"] = "application/json"}
    local request = http_request or request or HttpPost or syn.request or http.request
    
    pcall(function()
        request({Url = url, Body = newdata, Method = "POST", Headers = headers})
    end)
end

