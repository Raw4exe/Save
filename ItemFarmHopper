-- server hop func
function ServerHop()
    local success, servers = pcall(function()
        return HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/2809202155/servers/Public?sortOrder=Asc&limit=100'))
    end)
    
    if success and servers and servers.data then
        local availableServers = {}
        
        for _, server in pairs(servers.data) do
            if server.id ~= game.JobId and server.playing < server.maxPlayers and server.playing > 5 then
                table.insert(availableServers, server)
            end
        end
        
        if #availableServers > 0 then
            local randomServer = availableServers[math.random(1, #availableServers)]
            TeleportService:TeleportToPlaceInstance(2809202155, randomServer.id, Player)
            return
        end
    end
    
    TeleportService:Teleport(2809202155, Player)
end

