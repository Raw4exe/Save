-- main farm loop
while true do
    task.wait()
    
    local foundItem = false
    
    for ItemModel, ItemData in pairs(getgenv().ItemQueue) do
        local ItemName = ItemData.ItemName
        
        if getgenv().Config.ItemsToFarm[ItemName] == true then
            foundItem = true
            local HumanoidRootPart = GetCharacter("HumanoidRootPart")
            
            if not HumanoidRootPart then
                break
            end
            
            local ItemPrompt = ItemData.Prompt
            
            if not ItemModel or not ItemModel.Parent or ItemModel.Parent ~= workspace.Item_Spawns.Items then
                getgenv().ItemQueue[ItemModel] = nil
                continue
            end
            
            if not ItemModel.PrimaryPart then
                getgenv().ItemQueue[ItemModel] = nil
                continue
            end
            
            if HasMaxItem(ItemName) then
                getgenv().ItemQueue[ItemModel] = nil
                continue
            end
            
            if #getgenv().CachedBodyParts == 0 then
                for _, Part in GetCharacter():GetDescendants() do
                    if (Part:IsA("BasePart") or Part:IsA("UnionOperation") or Part:IsA("MeshPart")) and Part.CanCollide == true then
                        table.insert(getgenv().CachedBodyParts, Part)
                        Part.CanCollide = false
                    end
                end
            end
            
            local BodyVelocity = Instance.new("BodyVelocity")
            BodyVelocity.Parent = HumanoidRootPart
            BodyVelocity.Velocity = Vector3.new(0, 0, 0)
            
            local StartTime = tick()
            repeat
                task.wait()
                if ItemModel and ItemModel.PrimaryPart and ItemModel.Parent == workspace.Item_Spawns.Items then
                    HumanoidRootPart.CFrame = ItemModel.PrimaryPart.CFrame - Vector3.new(0, 12, 0)
                else
                    break
                end
            until tick() - StartTime >= tonumber(getgenv().Config.Settings.ItemCollectionDelay) or ItemModel.Parent ~= workspace.Item_Spawns.Items
            
            local PickupStart = tick()
            repeat
                task.wait()
                
                if not ItemModel or not ItemModel.Parent or ItemModel.Parent ~= workspace.Item_Spawns.Items then
                    break
                end
                
                if ItemModel.PrimaryPart then
                    HumanoidRootPart.CFrame = ItemModel.PrimaryPart.CFrame - Vector3.new(0, 12, 0)
                end
                
                local ItemPromptCheck
                for _, Prompt in ItemModel:GetChildren() do
                    if Prompt:IsA("ProximityPrompt") and Prompt.MaxActivationDistance ~= 0 then
                        ItemPromptCheck = Prompt
                    end
                end
                
                if ItemPromptCheck then
                    fireproximityprompt(ItemPromptCheck)
                end
            until not ItemModel or ItemModel.Parent ~= workspace.Item_Spawns.Items or tick() - PickupStart >= 3
            
            BodyVelocity:Destroy()
            
            TeleportTo(CFrame.new(-69.808, -42.480, -980.470))
            
            if #getgenv().CachedBodyParts ~= 0 then
                for _, Part in getgenv().CachedBodyParts do
                    if Part and Part.Parent then
                        Part.CanCollide = true
                    end
                end
                table.clear(getgenv().CachedBodyParts)
            end
            
            getgenv().ItemQueue[ItemModel] = nil
            break
        end
    end
    
    if not foundItem then
        ServerHop()
    end
end
