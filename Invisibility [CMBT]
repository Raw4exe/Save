local function PlayAnimation(AnimationID, AnimationSpeed, Time)
  local CreatedAnimation = Instance.new("Animation")
  CreatedAnimation.AnimationId = AnimationID
  local Humanoid = Character:FindFirstChild("Humanoid") or Character:WaitForChild("Humanoid")
  local Animator = Humanoid:FindFirstChild("Animator") or Humanoid:WaitForChild("Animator", 3)
  local AnimationTrack = Animator:LoadAnimation(CreatedAnimation)
  
  AnimationTrack:Play()
  AnimationTrack:AdjustSpeed(AnimationSpeed)
  AnimationTrack.Priority = Enum.AnimationPriority.Action4
  AnimationTrack.TimePosition = Time
  return AnimationTrack
end

